# ==============================================
# TTS Nma - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# Run: flutter run -d chrome --dart-define-from-file=.env

# Supabase (from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Edge Function secrets (set with Supabase CLI, do not expose in Flutter)
# npx supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
# npx supabase secrets set GROQ_API_KEY=...
# Optional: npx supabase secrets set GROQ_WHISPER_MODEL=whisper-large-v3
# npx supabase secrets set FISH_AUDIO_API_KEY=...
